# Firebase (client – safe to expose). Get these from Firebase Console > Project settings > General.
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_APP_ID=

# Admin password (must match the password used in the login popup). Set in Netlify as ADMIN_PASSWORD.
PUBLIC_ADMIN_PASSWORD=surfdelmar

# Netlify Functions only (set in Netlify UI, not in .env):
# ADMIN_PASSWORD=surfdelmar
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}  (paste full JSON from Firebase Console > Project settings > Service accounts > Generate new key)
