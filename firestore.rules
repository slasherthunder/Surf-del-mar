rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anyone to read schedule and image overrides (public site content)
    match /content/schedule {
      allow read: if true;
      allow write: if false;
    }
    match /content/imageOverrides {
      allow read: if true;
      allow write: if false;
    }
    match /content/maintenanceMode {
      allow read: if true;
      allow write: if false;
    }
    match /content/pageText {
      allow read: if true;
      allow write: if false;
    }
    // Shared memories: public read; writes only via server (Netlify function)
    match /sharedMemories/{id} {
      allow read: if true;
      allow write: if false;
    }
  }
}
