---
// Shown when user is logged in as admin. Links to edit calendar, photos, and full admin panel.
---
<div id="admin-bar" class="admin-bar" role="banner" aria-label="Admin toolbar" hidden>
	<span class="admin-bar-label">You're editing</span>
	<nav class="admin-bar-nav">
		<a href="/schedule/" class="admin-bar-link">Edit calendar</a>
	</nav>
	<button type="button" class="admin-bar-logout" id="admin-bar-logout">Log out</button>
</div>

<script>
	const bar = document.getElementById('admin-bar');
	const logoutBtn = document.getElementById('admin-bar-logout');

	function setBarVisible(visible) {
		if (bar) bar.hidden = !visible;
	}

	function checkAdmin() {
		setBarVisible(sessionStorage.getItem('admin') === 'true');
	}

	checkAdmin();
	window.addEventListener('admin-login', checkAdmin);

	logoutBtn?.addEventListener('click', () => {
		sessionStorage.removeItem('admin');
		setBarVisible(false);
		window.dispatchEvent(new CustomEvent('admin-logout'));
	});
</script>

<style>
	.admin-bar {
		position: sticky;
		top: 0;
		z-index: 1000;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.75rem;
		padding: 0.5rem 1.25rem;
		background: var(--color-ink);
		color: var(--color-cream);
		font-size: 0.8rem;
		font-weight: 600;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
	}
	.admin-bar[hidden] {
		display: none !important;
	}
	.admin-bar-label {
		letter-spacing: 0.04em;
	}
	.admin-bar-nav {
		display: flex;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
	}
	.admin-bar-link {
		color: var(--color-cream);
		text-decoration: none;
		opacity: 0.95;
		transition: opacity 0.2s ease;
	}
	.admin-bar-link:hover {
		opacity: 1;
		text-decoration: underline;
	}
	.admin-bar-logout {
		padding: 0.3rem 0.6rem;
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		background: rgba(255, 255, 255, 0.15);
		border: 1px solid rgba(255, 255, 255, 0.3);
		border-radius: 4px;
		color: var(--color-cream);
		cursor: pointer;
		font-family: inherit;
		transition: background 0.2s ease;
	}
	.admin-bar-logout:hover {
		background: rgba(255, 255, 255, 0.25);
	}
</style>
