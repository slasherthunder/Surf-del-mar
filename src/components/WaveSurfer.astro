---
---
<!-- Environmental layering: tube effect with back wave, surfer, and foreground foam -->
<div class="wave-surfer-wrap" id="wave-surfer-wrap">
	<div class="wave-tube" aria-hidden="true">
		<!-- Background wave: solid wave face (inside the tube) -->
		<svg class="tube-back-wave" viewBox="0 0 1200 120" preserveAspectRatio="none">
			<defs>
				<linearGradient id="tube-wave-fill" x1="0%" y1="0%" x2="100%" y2="0%">
					<stop offset="0%" stop-color="var(--wave-deep)" />
					<stop offset="50%" stop-color="var(--wave-mid)" />
					<stop offset="100%" stop-color="var(--wave-deep)" />
				</linearGradient>
			</defs>
			<path d="M0,60 Q200,20 400,50 T800,45 T1200,55 L1200,120 L0,120 Z" fill="url(#tube-wave-fill)" />
		</svg>
		<!-- Foreground foam: translucent white-water for depth -->
		<svg class="tube-foam" viewBox="0 0 1200 120" preserveAspectRatio="none">
			<defs>
				<linearGradient id="tube-foam-fill" x1="0%" y1="0%" x2="0%" y2="100%">
					<stop offset="0%" stop-color="rgba(255,255,255,0.5)" />
					<stop offset="40%" stop-color="rgba(255,255,255,0.15)" />
					<stop offset="100%" stop-color="rgba(255,255,255,0)" />
				</linearGradient>
			</defs>
			<path d="M0,30 Q120,12 240,35 T480,28 T720,40 T960,25 T1200,35 L1200,90 Q960,55 720,75 Q480,60 240,80 Q0,70 0,90 Z" fill="url(#tube-foam-fill)" />
		</svg>
	</div>

	<button
		type="button"
		class="surfer"
		aria-label="Click to watch the surfer ride the wave"
		title="Click to surf!"
	>
		<span class="spray" aria-hidden="true"></span>
		<!-- Professional silhouette: low CG, bent knees, front arm forward, board with fin -->
		<svg class="surfer-svg" viewBox="0 0 36 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
			<!-- Board shadow (thickness) -->
			<ellipse cx="18" cy="28" rx="14" ry="1.5" fill="currentColor" opacity="0.25" />
			<!-- Shortboard: tapered with visible fin -->
			<path d="M2,26 C6,24 28,24 34,26 L32,28 C26,27 10,27 4,28 Z" fill="currentColor" opacity="0.85" />
			<!-- Fin -->
			<path d="M4,26 L5,28 L6,26 Z" fill="currentColor" opacity="0.7" />
			<!-- Head -->
			<circle cx="24" cy="6" r="2.5" fill="currentColor" />
			<!-- Torso - low, leaned forward -->
			<path d="M24,8.5 L20,14 L16,16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
			<!-- Back arm - balance, raised -->
			<path d="M20,14 L27,12 L30,14" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
			<!-- Front arm - reach forward, carving -->
			<path d="M20,14 L14,10 L8,12" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
			<!-- Legs - bent knees, athletic crouch -->
			<path d="M16,16 L14,21 L12,26" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
			<path d="M18,16 L20,21 L24,26" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
		</svg>
	</button>
	<!-- Invisible path for motion -->
	<svg class="motion-path-svg" viewBox="0 0 1200 100" preserveAspectRatio="none" aria-hidden="true">
		<path id="surfer-path" d="M0,50 C150,20 250,80 400,50 C550,20 650,80 800,50 C950,20 1050,80 1200,50" />
	</svg>
</div>

<script>
	const surfer = document.querySelector('.surfer');
	const wrap = document.getElementById('wave-surfer-wrap');
	const variants = ['v1', 'v2', 'v3', 'v4'];

	if (surfer) {
		surfer.addEventListener('click', () => {
			if (surfer.classList.contains('surfing')) return;
			const variant = variants[Math.floor(Math.random() * variants.length)];
			surfer.classList.remove('surf-v1', 'surf-v2', 'surf-v3', 'surf-v4');
			surfer.classList.add('surfing', `surf-${variant}`);
		});
		surfer.addEventListener('animationend', (e) => {
			if (e.animationName.includes('ride-wave')) {
				surfer.classList.remove('surfing', 'surf-v1', 'surf-v2', 'surf-v3', 'surf-v4');
				// Finish polish: splash / screen-shake
				if (wrap) {
					wrap.classList.remove('surf-finish');
					void wrap.offsetWidth; // reflow
					wrap.classList.add('surf-finish');
					setTimeout(() => wrap.classList.remove('surf-finish'), 400);
				}
			}
		});
	}
</script>

<style>
	.wave-surfer-wrap {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 10;
		transition: transform 0.05s ease-out;
	}

	/* Finish polish: subtle screen-shake */
	.wave-surfer-wrap.surf-finish {
		animation: finish-shake 0.4s ease-out;
	}
	@keyframes finish-shake {
		0%, 100% { transform: translateX(0) translateY(0); }
		15% { transform: translateX(-2px) translateY(1px); }
		30% { transform: translateX(2px) translateY(-1px); }
		45% { transform: translateX(-1px) translateY(0); }
		60% { transform: translateX(1px) translateY(1px); }
		75% { transform: translateX(-1px) translateY(0); }
	}

	/* Tube: back wave + foam create "inside the wave" depth */
	.wave-tube {
		position: absolute;
		inset: 0;
		overflow: hidden;
		pointer-events: none;
		z-index: 1;
	}
	.tube-back-wave {
		position: absolute;
		bottom: 0;
		left: 0;
		width: 100%;
		height: 100%;
		min-height: 120px;
		opacity: 0.65;
	}
	.tube-foam {
		position: absolute;
		bottom: 0;
		left: 0;
		width: 100%;
		height: 100%;
		min-height: 120px;
		z-index: 3;
		pointer-events: none;
	}

	.surfer {
		pointer-events: auto;
		position: absolute;
		left: 3%;
		bottom: 52%;
		width: 32px;
		height: 28px;
		padding: 0;
		border: none;
		background: none;
		cursor: pointer;
		z-index: 2;
		offset-distance: 0%;
		/* Dynamic banking: board stays tangential to wave path */
		offset-rotate: auto;
		transition: transform 0.2s;
		offset-path: path("M 0 25 C 150 15 250 15 400 25 C 550 15 650 15 800 25 C 950 15 1050 15 1200 25");
		/* Buoyant sine-like bob */
		animation: surfer-bob 2.5s cubic-bezier(0.445, 0.05, 0.55, 0.95) infinite;
	}

	.surfer.surfing {
		animation: ride-wave var(--surf-duration) var(--surf-easing) forwards;
	}

	@keyframes surfer-bob {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-5px); }
	}

	/* Path variants */
	.surfer.surf-v1 {
		offset-path: path("M 0 25 C 150 15 250 15 400 25 C 550 15 650 15 800 25 C 950 15 1050 15 1200 25");
	}
	.surfer.surf-v2 {
		offset-path: path("M 0 35 C 200 10 400 40 600 15 C 800 45 1000 20 1200 35");
	}
	.surfer.surf-v3 {
		offset-path: path("M 0 20 C 300 35 400 15 700 30 C 900 10 1100 25 1200 20");
	}
	.surfer.surf-v4 {
		offset-path: path("M 0 30 C 250 28 500 32 750 28 C 1000 33 1200 30 1200 30");
	}

	.surfer:hover:not(.surfing) {
		animation-duration: 1.8s;
	}
	.surfer:active:not(.surfing) {
		animation-duration: 2.5s;
	}

	.surfer-svg {
		width: 100%;
		height: 100%;
		display: block;
		color: #fff;
		filter: drop-shadow(0 1px 3px rgba(0,0,0,0.5));
		position: relative;
		z-index: 1;
	}

	.surfer.surfing .surfer-svg {
		filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.5));
	}

	/* Spray: water particles behind board when surfing */
	.spray {
		position: absolute;
		top: 50%;
		left: -8px;
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.5);
		opacity: 0;
		pointer-events: none;
		z-index: 0;
		box-shadow:
			4px -2px 0 0 rgba(255,255,255,0.35),
			-2px -4px 0 0 rgba(255,255,255,0.25),
			6px 2px 0 0 rgba(255,255,255,0.2),
			-4px 0 0 0 rgba(255,255,255,0.3),
			2px 2px 0 0 rgba(255,255,255,0.15);
	}
	.surfer.surfing .spray {
		opacity: 1;
		animation: spray-particles 0.15s ease-out infinite;
	}
	.surfer.surf-v2.surfing .spray {
		--spray-opacity: 0.9;
		box-shadow:
			6px -3px 0 0 rgba(255,255,255,0.5),
			-3px -6px 0 0 rgba(255,255,255,0.4),
			8px 3px 0 0 rgba(255,255,255,0.35),
			-6px 0 0 0 rgba(255,255,255,0.45),
			4px 3px 0 0 rgba(255,255,255,0.3),
			-2px -2px 0 0 rgba(255,255,255,0.25);
		animation: spray-particles 0.08s ease-out infinite;
	}

	@keyframes spray-particles {
		0% {
			transform: scale(0.8);
			opacity: 0.4;
		}
		50% {
			transform: scale(1.2);
			opacity: var(--spray-opacity, 0.7);
		}
		100% {
			transform: scale(0.9);
			opacity: 0.3;
		}
	}

	/* Wake trail (legacy speed-blur enhanced) */
	.surfer.surfing::after {
		content: '';
		position: absolute;
		top: 85%;
		left: -24px;
		width: 48px;
		height: 6px;
		background: radial-gradient(ellipse at center, rgba(255,255,255,0.5) 0%, transparent 70%);
		border-radius: 50%;
		filter: blur(6px);
		opacity: 0.5;
		pointer-events: none;
		z-index: 0;
		animation: wake-blur 0.2s infinite alternate;
	}
	.surfer.surf-v2.surfing::after {
		width: 60px;
		height: 8px;
		opacity: 0.7;
		animation-duration: 0.12s;
	}

	@keyframes wake-blur {
		from { transform: scaleX(0.9); opacity: 0.4; }
		to { transform: scaleX(1.4); opacity: 0.6; }
	}

	.surfer.surf-v1 { --surf-duration: 2.5s; --surf-easing: cubic-bezier(0.25, 0.46, 0.45, 0.94); }
	.surfer.surf-v2 { --surf-duration: 2s;   --surf-easing: cubic-bezier(0.68, -0.55, 0.27, 1.55); }
	.surfer.surf-v3 { --surf-duration: 1.8s; --surf-easing: cubic-bezier(0.4, 0, 0.6, 1); }
	.surfer.surf-v4 { --surf-duration: 3.2s; --surf-easing: cubic-bezier(0.22, 1, 0.36, 1); }

	@keyframes ride-wave {
		0% { offset-distance: 0%; }
		100% { offset-distance: 100%; }
	}

	/* Fallback for browsers without offset-path */
	@supports not (offset-path: path("M0 0")) {
		.surfer {
			offset-path: none;
			left: 3%;
		}
		.surfer.surf-v1.surfing { animation: ride-fallback 2.5s ease-out forwards; }
		.surfer.surf-v2.surfing { animation: ride-fallback 2s cubic-bezier(0.68, -0.55, 0.27, 1.55) forwards; }
		.surfer.surf-v3.surfing { animation: ride-fallback 1.8s ease-in-out forwards; }
		.surfer.surf-v4.surfing { animation: ride-fallback 3.2s ease-in-out forwards; }
		@keyframes ride-fallback {
			0% { left: 3%; transform: translateY(0); }
			20% { transform: translateY(-15px); }
			40% { transform: translateY(-3px); }
			60% { transform: translateY(-12px); }
			80% { transform: translateY(-6px); }
			100% { left: 85%; transform: translateY(0); }
		}
	}

	.motion-path-svg {
		position: absolute;
		width: 0;
		height: 0;
		overflow: hidden;
		opacity: 0;
	}

	@media (max-width: 768px) {
		.surfer {
			width: 26px;
			height: 22px;
			left: 2%;
			bottom: 48%;
		}
		@keyframes surfer-bob {
			0%, 100% { transform: translateY(0); }
			50% { transform: translateY(-3px); }
		}
		.surfer:hover:not(.surfing) {
			animation-duration: 2s;
		}
		.surfer.surf-v1 { --surf-duration: 2s; }
		.surfer.surf-v2 { --surf-duration: 1.6s; }
		.surfer.surf-v3 { --surf-duration: 1.5s; }
		.surfer.surf-v4 { --surf-duration: 2.5s; }
	}
	@media (max-width: 768px) {
		.wave-surfer-wrap.surf-finish {
			animation: finish-shake-mobile 0.35s ease-out;
		}
		@keyframes finish-shake-mobile {
			0%, 100% { transform: translateX(0) translateY(0); }
			25% { transform: translateX(-1px) translateY(0); }
			75% { transform: translateX(1px) translateY(0); }
		}
	}
</style>
