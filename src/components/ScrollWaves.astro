---
interface Props {
	variant?: 'light' | 'dark';
}

const { variant = 'light' } = Astro.props;
---

<div class="scroll-waves" data-variant={variant} aria-hidden="true">
	<div class="wave-layer wave-1">
		<div class="wave-drift">
			<!-- C1-smooth cubic beziers: control points reflect at each join for no cusps -->
			<svg viewBox="0 0 1200 100" preserveAspectRatio="none">
				<path d="M0,50 C150,20 250,80 400,50 C550,20 650,80 800,50 C950,20 1050,80 1200,50 L1200,100 L0,100 Z" />
			</svg>
			<svg viewBox="0 0 1200 100" preserveAspectRatio="none">
				<path d="M0,50 C150,20 250,80 400,50 C550,20 650,80 800,50 C950,20 1050,80 1200,50 L1200,100 L0,100 Z" />
			</svg>
		</div>
	</div>
	<div class="wave-layer wave-2">
		<div class="wave-drift">
			<svg viewBox="0 0 1200 100" preserveAspectRatio="none">
				<path d="M0,55 C180,25 220,85 400,55 C580,25 620,85 800,55 C980,25 1020,85 1200,55 L1200,100 L0,100 Z" />
			</svg>
			<svg viewBox="0 0 1200 100" preserveAspectRatio="none">
				<path d="M0,55 C180,25 220,85 400,55 C580,25 620,85 800,55 C980,25 1020,85 1200,55 L1200,100 L0,100 Z" />
			</svg>
		</div>
	</div>
	<div class="wave-layer wave-3">
		<div class="wave-drift">
			<svg viewBox="0 0 1200 100" preserveAspectRatio="none">
				<path d="M0,45 C160,65 240,25 400,45 C560,65 640,25 800,45 C960,65 1040,25 1200,45 L1200,100 L0,100 Z" />
			</svg>
			<svg viewBox="0 0 1200 100" preserveAspectRatio="none">
				<path d="M0,45 C160,65 240,25 400,45 C560,65 640,25 800,45 C960,65 1040,25 1200,45 L1200,100 L0,100 Z" />
			</svg>
		</div>
	</div>
</div>


<style>
	.scroll-waves {
		position: relative;
		width: 100%;
		height: 100px;
		overflow: hidden;
	}

	.wave-layer {
		position: absolute;
		bottom: 0;
		left: 0;
		width: 100%;
		height: 100px;
		overflow: hidden;
		/* Soften edges where waves overlap - eliminates harsh lines */
		filter: blur(0.8px);
	}

	.wave-drift {
		display: flex;
		width: max-content;
		height: 100%;
		min-width: 200%;
		animation: wave-drift var(--wave-duration) linear infinite;
	}

	.wave-drift svg {
		flex: 0 0 50%;
		width: 50%;
	}

	.wave-1 .wave-drift { --wave-duration: 8s; }
	.wave-2 .wave-drift { --wave-duration: 12s; animation-direction: reverse; }
	.wave-3 .wave-drift { --wave-duration: 10s; animation-delay: -2s; }

	@keyframes wave-drift {
		0% { transform: translateX(0); }
		100% { transform: translateX(-50%); }
	}

	.wave-layer svg {
		width: 100%;
		height: 100%;
		display: block;
	}

	.wave-layer path {
		fill: currentColor;
		opacity: 0.8;
		shape-rendering: geometricPrecision;
	}

	/* California Pacific waves: for dark section backgrounds (hero) */
	.scroll-waves[data-variant="light"] .wave-1 { color: var(--wave-light); }
	.scroll-waves[data-variant="light"] .wave-2 { color: var(--wave-mid); }
	.scroll-waves[data-variant="light"] .wave-3 { color: var(--wave-deep); }

	/* California Pacific waves: for light section backgrounds (gallery, intro) */
	.scroll-waves[data-variant="dark"] .wave-1 { color: var(--wave-mid); }
	.scroll-waves[data-variant="dark"] .wave-2 { color: var(--wave-deep); }
	.scroll-waves[data-variant="dark"] .wave-3 { color: var(--wave-light); }
</style>
