---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Manage Memories" description="Moderate shared Surfers Reunion memories.">
	<section class="admin-memories-hero">
		<div class="container">
			<h1 class="admin-memories-title">Manage Memories</h1>
			<p class="admin-memories-desc">Approve, hide, or delete user-submitted memories. You must be logged in as admin.</p>
		</div>
	</section>

	<div id="admin-memories-gate" class="admin-memories-gate">
		<p>Log in as admin (use Admin Login in the nav) to manage memories.</p>
		<a href="/schedule/" class="btn btn-primary">Go to Schedule</a>
	</div>

	<div id="admin-memories-root" class="admin-memories-root" hidden aria-busy="true">
		<p id="admin-memories-loading">Loading…</p>
		<div id="admin-memories-list" class="admin-memories-list"></div>
	</div>

	<script>
		import { getSharedMemories } from '../../lib/firebase';

		const ADMIN_PASSWORD = typeof import.meta.env.PUBLIC_ADMIN_PASSWORD === 'string' && import.meta.env.PUBLIC_ADMIN_PASSWORD
			? import.meta.env.PUBLIC_ADMIN_PASSWORD
			: 'surfdelmar';

		const gateEl = document.getElementById('admin-memories-gate');
		const rootEl = document.getElementById('admin-memories-root');
		const loadingEl = document.getElementById('admin-memories-loading');
		const listEl = document.getElementById('admin-memories-list');

		function escapeHtml(s) {
			const div = document.createElement('div');
			div.textContent = s ?? '';
			return div.innerHTML;
		}

		async function load() {
			const isAdmin = sessionStorage.getItem('admin') === 'true';
			if (!isAdmin) {
				if (gateEl) gateEl.hidden = false;
				if (rootEl) rootEl.hidden = true;
				return;
			}
			if (gateEl) gateEl.hidden = true;
			if (rootEl) rootEl.hidden = false;
			const result = await getSharedMemories();
			if (loadingEl) loadingEl.hidden = true;
			if (!result.ok) {
				if (listEl) listEl.innerHTML = `<p class="admin-memories-error">Failed to load: ${escapeHtml(result.error)}</p>`;
				return;
			}
			const memories = result.memories;
			if (memories.length === 0) {
				if (listEl) listEl.innerHTML = '<p class="admin-memories-msg">No submitted memories yet.</p>';
				return;
			}
			listEl.innerHTML = memories.map((m) => {
				const dateStr = m.submittedAt && typeof m.submittedAt === 'object' && 'seconds' in m.submittedAt
					? new Date(m.submittedAt.seconds * 1000).toLocaleString()
					: '—';
				const approved = m.approved !== false;
				return `
					<article class="admin-memory-card" data-id="${escapeHtml(m.id)}">
						<div class="admin-memory-preview">
							${m.imageUrl ? `<img src="${escapeHtml(m.imageUrl)}" alt="" class="admin-memory-img" loading="lazy" />` : '<span>No image</span>'}
						</div>
						<div class="admin-memory-meta">
							<p><strong>${escapeHtml(m.caption || '—')}</strong></p>
							<p>${escapeHtml(m.name || '—')} · ${escapeHtml(dateStr)}</p>
							<p>Likes: ${m.likes ?? 0}</p>
							<p class="admin-memory-status">${approved ? 'Visible' : 'Hidden'}</p>
							<div class="admin-memory-actions">
								${!approved ? `<button type="button" class="btn btn-sm btn-approve">Approve</button>` : ''}
								${approved ? `<button type="button" class="btn btn-sm btn-hide">Hide</button>` : ''}
								<button type="button" class="btn btn-sm btn-danger btn-delete">Delete</button>
							</div>
						</div>
					</article>`;
			}).join('');

			listEl.querySelectorAll('.btn-approve').forEach((btn) => {
				btn.addEventListener('click', async () => {
					const card = btn.closest('.admin-memory-card');
					const id = card?.dataset.id;
					if (!id) return;
					await fetch('/.netlify/functions/admin-memory', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ password: ADMIN_PASSWORD, action: 'approve', memoryId: id }),
					});
					load();
					window.dispatchEvent(new CustomEvent('show-admin-toast', { detail: { message: 'Approved.' } }));
				});
			});
			listEl.querySelectorAll('.btn-hide').forEach((btn) => {
				btn.addEventListener('click', async () => {
					const card = btn.closest('.admin-memory-card');
					const id = card?.dataset.id;
					if (!id) return;
					await fetch('/.netlify/functions/admin-memory', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ password: ADMIN_PASSWORD, action: 'hide', memoryId: id }),
					});
					load();
					window.dispatchEvent(new CustomEvent('show-admin-toast', { detail: { message: 'Hidden.' } }));
				});
			});
			listEl.querySelectorAll('.btn-delete').forEach((btn) => {
				btn.addEventListener('click', async () => {
					if (!confirm('Permanently delete this memory?')) return;
					const card = btn.closest('.admin-memory-card');
					const id = card?.dataset.id;
					if (!id) return;
					await fetch('/.netlify/functions/admin-memory', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ password: ADMIN_PASSWORD, action: 'delete', memoryId: id }),
					});
					load();
					window.dispatchEvent(new CustomEvent('show-admin-toast', { detail: { message: 'Deleted.' } }));
				});
			});
		}

		load();
		window.addEventListener('admin-login', load);
	</script>
</BaseLayout>

<style>
	.admin-memories-hero {
		padding: 2rem 1.5rem;
		text-align: center;
		background: var(--color-sand);
	}
	.admin-memories-title {
		font-family: var(--font-display);
		font-size: 1.75rem;
		font-weight: 600;
		color: var(--color-ink);
		margin: 0 0 0.5rem 0;
	}
	.admin-memories-desc {
		font-size: 1rem;
		color: var(--color-sepia);
		margin: 0;
	}
	.admin-memories-gate {
		padding: 3rem 2rem;
		text-align: center;
	}
	.admin-memories-gate p {
		margin-bottom: 1rem;
	}
	.admin-memories-root {
		padding: 2rem 1.5rem;
	}
	.admin-memories-list {
		display: grid;
		gap: 1.5rem;
		max-width: 900px;
		margin: 0 auto;
	}
	.admin-memory-card {
		display: flex;
		gap: 1.25rem;
		align-items: flex-start;
		padding: 1rem;
		background: rgba(255,255,255,0.5);
		border-radius: 12px;
		border: 1px solid rgba(0,0,0,0.08);
	}
	.admin-memory-preview {
		flex-shrink: 0;
		width: 120px;
		height: 90px;
		background: #eee;
		border-radius: 8px;
		overflow: hidden;
	}
	.admin-memory-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.admin-memory-meta {
		flex: 1;
		min-width: 0;
	}
	.admin-memory-meta p {
		margin: 0 0 0.35rem 0;
		font-size: 0.95rem;
	}
	.admin-memory-status {
		font-size: 0.85rem;
		color: var(--color-sepia);
	}
	.admin-memory-actions {
		display: flex;
		gap: 0.5rem;
		margin-top: 0.75rem;
	}
	.btn-sm {
		padding: 0.4rem 0.75rem;
		font-size: 0.8rem;
	}
	.btn-approve { background: #15803d; color: #fff; border: none; border-radius: 6px; cursor: pointer; font-weight: 600; }
	.btn-hide { background: var(--color-sepia); color: #fff; border: none; border-radius: 6px; cursor: pointer; font-weight: 600; }
	.btn-danger { background: #b91c1c; color: #fff; border: none; border-radius: 6px; cursor: pointer; font-weight: 600; }
	.admin-memories-error, .admin-memories-msg { color: var(--color-sepia); }
</style>
