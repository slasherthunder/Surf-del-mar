---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Maintenance" description="Surf Del Mar is temporarily unavailable.">
	<section class="maintenance-hero">
		<div class="container">
			<h1 class="maintenance-title">We'll be right back</h1>
			<p class="maintenance-text">Surf Del Mar is currently being updated. Please check back soon.</p>
		</div>
	</section>
</BaseLayout>

<style>
	.maintenance-hero {
		min-height: 60vh;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		padding: 3rem 2rem;
		background: var(--color-sand);
	}
	.maintenance-title {
		font-family: var(--font-display);
		font-size: clamp(1.75rem, 4vw, 2.5rem);
		font-weight: 600;
		color: var(--color-ink);
		margin: 0 0 1rem 0;
	}
	.maintenance-text {
		font-size: 1.1rem;
		color: var(--color-sepia);
		margin: 0;
	}
</style>
