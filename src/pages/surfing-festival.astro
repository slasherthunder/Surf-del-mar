---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollWaves from '../components/ScrollWaves.astro';
import WaveSurfer from '../components/WaveSurfer.astro';
import PirateShip from '../components/PirateShip.astro';
import Lighthouse from '../components/Lighthouse.astro';
---

<BaseLayout title="Surfing Festival" description="Celebrate Del Mar's surfing heritage and the culture of the endless summer.">
	<section class="hero hero-sunset-bg">
		<div class="hero-content hero-entrance">
			<h1 class="hero-title">ABOUT SURF DEL MAR:</h1>
			<p class="tagline hero-tagline">Celebrate the waves, the culture, and the spirit of Del Mar.</p>
		</div>
	</section>
	<div class="wave-wrap wave-hero hero-sunset-bg" id="festival-wave-wrap">
		<ScrollWaves variant="light" />
		<WaveSurfer />
		<PirateShip />
		<Lighthouse toggleTargetId="festival-wave-wrap" />
	</div>

	<section class="festival-content">
		<div class="container">
			<p class="festival-intro">
				SURF DEL MAR is presented by the Del Mar Historical Society as part of its ongoing mission to preserve and celebrate the history and culture of our unique seaside community, and especially to honor the many people who have helped shape the culture and spirit of surfing over the years. At the heart of the festival is a multi-generational Surfers Reunion, bringing together people who rode Del Mar's waves in the 1950s and 60s—and even earlier— alongside today's surfers and the next generations to follow.
			</p>
			<h2 class="festival-subhead">SURF DEL MAR brings together many aspects of surf culture in one vibrant, festive event:</h2>
			<ul class="festival-list">
				<li>Surfers Reunion celebrating decades of Del Mar surf history</li>
				<li>Concerts with the MarDels and Peter Sprague</li>
				<li>Film Festival showcasing the classic Endless Summer and the debut of a Jim Lischer film on Del Mar surfers over the years</li>
				<li>Surfwriter's Book Fair featuring authors and publications dedicated to surfing</li>
				<li>Art Walk highlighting local artists and student artwork from Del Mar schools</li>
				<li>Surfing and Sustainability Climate Change Symposium exploring how surfers and coastal communities like Del Mar are responding to changing oceans and shorelines</li>
			</ul>
			<p class="festival-free">
				ALL EVENTS WILL BE FREE AND OPEN TO THE PUBLIC, WELCOMING RESIDENTS, VISITORS, SURFERS, FAMILIES AND ANYONE WHO SHARES A LOVE OF THE OCEAN
			</p>
			<h2 class="festival-tagline-heading">HONORING THE PAST—INSPIRING THE FUTURE</h2>
			<p class="festival-outro">
				By bringing together stories, art, film science and shared memories, SURF DEL MAR honors the pioneers who helped shape surf culture while inspiring future generations to care for the coast, the ocean, and the traditions that grew from them.
			</p>
		</div>
	</section>
</BaseLayout>

<style>
	.hero {
		color: var(--color-cream);
		padding: 4rem 2rem;
		text-align: center;
	}

	.wave-wrap {
		position: relative;
		overflow: visible;
		min-height: 120px;
	}

	.wave-wrap :global(.wave-surfer-wrap) {
		transition: opacity 0.4s ease, visibility 0.4s ease;
	}
	:global(.wave-wrap.pirate-mode) :global(.wave-surfer-wrap) {
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
	}

	.hero-content {
		max-width: 700px;
		margin: 0 auto;
	}

	.hero h1 {
		font-family: var(--font-display);
		font-size: clamp(2.5rem, 5vw, 4rem);
		font-weight: 600;
		letter-spacing: 0.02em;
		margin-bottom: 1rem;
		line-height: 1.2;
	}

	.hero-title {
		animation: hero-fade-up 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
	}
	.hero-tagline {
		opacity: 0;
		animation: hero-fade-up 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.2s forwards;
	}
	@keyframes hero-fade-up {
		from {
			opacity: 0;
			transform: translateY(30px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.tagline {
		font-size: 1.25rem;
		opacity: 0.95;
		font-weight: 400;
	}

	.festival-content {
		position: relative;
		z-index: 1;
		padding: 4rem 2rem;
		background: linear-gradient(180deg, #e8e0d6 0%, #ddd4c8 100%);
		box-shadow: inset 0 1px 0 rgba(255,255,255,0.4);
	}

	.festival-content .container {
		max-width: 820px;
		margin: 0 auto;
	}

	.festival-intro {
		font-family: var(--font-body);
		font-size: 1.0625rem;
		color: var(--color-ink);
		line-height: 1.75;
		margin: 0 0 1.75rem 0;
	}

	.festival-subhead {
		font-family: var(--font-display);
		font-size: clamp(1.25rem, 3vw, 1.5rem);
		font-weight: 600;
		color: var(--color-ink);
		margin: 0 0 1rem 0;
		line-height: 1.4;
	}

	.festival-list {
		font-family: var(--font-body);
		font-size: 1rem;
		color: var(--color-ink);
		line-height: 1.75;
		margin: 0 0 2rem 0;
		padding-left: 1.5rem;
		list-style: disc;
	}

	.festival-list li {
		margin-bottom: 0.5rem;
	}

	.festival-free {
		font-family: var(--font-body);
		font-size: 0.95rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-ink);
		line-height: 1.5;
		margin: 0 0 2rem 0;
		padding: 1.25rem 1.5rem;
		background: rgba(255, 255, 255, 0.5);
		border-left: 4px solid #8b7355;
		border-radius: 0 10px 10px 0;
	}

	.festival-tagline-heading {
		font-family: var(--font-body);
		font-size: clamp(1.1rem, 2.5vw, 1.35rem);
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-ink);
		margin: 0 0 1rem 0;
		line-height: 1.35;
	}

	.festival-outro {
		font-family: var(--font-body);
		font-size: 1.0625rem;
		color: var(--color-ink);
		line-height: 1.75;
		margin: 0;
	}
</style>
