---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollWaves from '../components/ScrollWaves.astro';
import WaveSurfer from '../components/WaveSurfer.astro';
import PirateShip from '../components/PirateShip.astro';
import Lighthouse from '../components/Lighthouse.astro';
---

<BaseLayout title="Surfing Festival" description="Celebrate Del Mar's surfing heritage and the culture of the endless summer.">
	<section class="hero hero-sunset-bg">
		<div class="hero-content hero-entrance">
			<h1 class="hero-title">Surfing Festival</h1>
			<p class="tagline hero-tagline">Celebrate the waves, the culture, and the spirit of Del Mar.</p>
		</div>
	</section>
	<div class="wave-wrap wave-hero hero-sunset-bg" id="festival-wave-wrap">
		<ScrollWaves variant="light" />
		<WaveSurfer />
		<PirateShip />
		<Lighthouse toggleTargetId="festival-wave-wrap" />
	</div>

	<section class="festival-content">
		<div class="container event-guide">
			<header class="section-header">
				<span class="eyebrow">4-Day Event Guide</span>
				<h2>Ride the Legacy</h2>
			</header>
			<p class="festival-intro">
				The Del Mar Historical Society is planning an epic 4-day Surfing Festival to celebrate Del Mar's iconic role in the early days of surfing.
			</p>
			<div class="event-cards">
				<article class="event-card">
					<h3>Reunion & Music</h3>
					<p>An Opening Night Surfers' Reunion at the Del Mar Plaza with music by Peter Sprague and his group. A Surfers' Reunion in Seagrove Park: Celebrating Surf and Stories Over The Years.</p>
				</article>
				<article class="event-card">
					<h3>Art & Literature</h3>
					<p>A Surfwriter's Book Fair featuring authors, historians and surf publications. Art Walks showcasing the work of local artists who have captured the world of surfing in their artwork, along with art projects from students at local Del Mar schools.</p>
				</article>
				<article class="event-card">
					<h3>Cinema</h3>
					<p>An evening screening of the legendary Bruce Brown film <em>Endless Summer</em>. The premiere of former Del Mar lifeguard Jim Lischer's new film featuring Del Mar surfers over the years. A Film Festival featuring old and new films of classic surfing over the years.</p>
				</article>
				<article class="event-card event-card-advocacy">
					<h3>Advocacy</h3>
					<p>A Climate Change and Surf Symposium: How Surfers Are Helping to Save Our Beaches and Bluffs, with speakers from Scripps Institute of Oceanography and surfing equipment manufacturers.</p>
				</article>
				<article class="event-card">
					<h3>Live Performance</h3>
					<p>A Live Concert with beloved local band The MarDels.</p>
				</article>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.hero {
		color: var(--color-cream);
		padding: 4rem 2rem;
		text-align: center;
	}

	.wave-wrap {
		position: relative;
		overflow: visible;
		min-height: 120px;
	}

	.wave-wrap :global(.wave-surfer-wrap) {
		transition: opacity 0.4s ease, visibility 0.4s ease;
	}
	:global(.wave-wrap.pirate-mode) :global(.wave-surfer-wrap) {
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
	}

	.hero-content {
		max-width: 700px;
		margin: 0 auto;
	}

	.hero h1 {
		font-family: var(--font-display);
		font-size: clamp(2.5rem, 5vw, 4rem);
		font-weight: 600;
		letter-spacing: 0.02em;
		margin-bottom: 1rem;
		line-height: 1.2;
	}

	.hero-title {
		animation: hero-fade-up 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
	}
	.hero-tagline {
		opacity: 0;
		animation: hero-fade-up 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.2s forwards;
	}
	@keyframes hero-fade-up {
		from {
			opacity: 0;
			transform: translateY(30px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.tagline {
		font-size: 1.25rem;
		opacity: 0.95;
		font-weight: 400;
	}

	.festival-content {
		position: relative;
		z-index: 1;
		padding: 4rem 2rem;
		background: linear-gradient(180deg, #e8e0d6 0%, #ddd4c8 100%);
		box-shadow: inset 0 1px 0 rgba(255,255,255,0.4);
	}

	.festival-content .container {
		max-width: 820px;
		margin: 0 auto;
	}

	.section-header {
		margin-bottom: 1rem;
	}

	.section-header .eyebrow {
		display: block;
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--color-sepia);
		margin-bottom: 0.5rem;
		font-family: var(--font-body);
	}

	.section-header h2 {
		font-family: var(--font-display);
		font-size: clamp(1.75rem, 4vw, 2.25rem);
		font-weight: 600;
		color: var(--color-ink);
		margin: 0;
		line-height: 1.25;
	}

	.festival-intro {
		font-family: var(--font-body);
		font-size: 1.0625rem;
		color: var(--color-ink);
		line-height: 1.7;
		margin-bottom: 2rem;
	}

	.event-cards {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.25rem;
	}

	@media (min-width: 640px) {
		.event-cards {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 900px) {
		.event-cards {
			grid-template-columns: repeat(2, 1fr);
			gap: 1.5rem;
		}
	}

	.event-card {
		background: rgba(255, 255, 255, 0.4);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		padding: 1.5rem 1.5rem 1.5rem 1.25rem;
		border-radius: 12px;
		border: 1px solid rgba(255, 255, 255, 0.5);
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
		border-left: 6px solid #8b7355;
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}

	.event-card:hover {
		transform: translateX(10px);
		box-shadow: 0 8px 28px rgba(0, 0, 0, 0.08);
	}

	.event-card h3 {
		font-family: var(--font-display);
		font-size: 1.2rem;
		font-weight: 600;
		color: var(--color-ink);
		margin: 0 0 0.6rem 0;
		line-height: 1.3;
	}

	.event-card p {
		font-family: var(--font-body);
		font-size: 1rem;
		color: var(--color-ink);
		line-height: 1.7;
		margin: 0;
	}

	.event-card-advocacy {
		border-left-color: #e6b800;
		background: rgba(255, 248, 220, 0.35);
		box-shadow: 0 4px 20px rgba(230, 184, 0, 0.08);
	}

	.event-card-advocacy:hover {
		box-shadow: 0 8px 28px rgba(230, 184, 0, 0.12);
	}
</style>
