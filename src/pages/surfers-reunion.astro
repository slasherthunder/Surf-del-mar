---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollWaves from '../components/ScrollWaves.astro';
import WaveSurfer from '../components/WaveSurfer.astro';
import PirateShip from '../components/PirateShip.astro';
import Lighthouse from '../components/Lighthouse.astro';
---

<BaseLayout title="Surfers Reunion" description="A gathering of generations—Del Mar surfers past and present, together again.">
	<section class="hero hero-sunset-bg">
		<div class="hero-content hero-entrance">
			<h1 class="hero-title">SURFERS REUNION</h1>
			<p class="tagline hero-tagline">A Gathering of Generations</p>
		</div>
	</section>
	<div class="wave-wrap wave-hero hero-sunset-bg" id="reunion-wave-wrap">
		<ScrollWaves variant="light" />
		<WaveSurfer />
		<PirateShip />
		<Lighthouse toggleTargetId="reunion-wave-wrap" />
	</div>

	<section class="reunion-content">
		<div class="container">
			<article class="event-card event-card-intro">
				<p class="reunion-intro">
					For decades, surfers have gathered along our local beaches to ride the waves, and share stories, building a unique coastal culture. SURF DEL MAR brings these generations together again.
				</p>
				<p class="reunion-intro">
					From the pioneers who surfed here in the 1930s, like XXXXXXX, and into the 1950s and 60s, to today's surfers and young riders, this reunion invites everyone connected to Del Mar and the surrounding surf communities to come together and celebrate.
				</p>
			</article>

			<h2 class="reunion-subhead">REMEMBERING THE WAVES</h2>
			<p class="reunion-lead">Throughout the SURF DEL MAR weekend, reunion events will include;</p>
			<ul class="reunion-list">
				<li>Informal gatherings and storytelling with surfers from different eras</li>
				<li>Historic photographs and shared memories from Del Mar's early surf days</li>
				<li>Film screenings celebrating classic surf culture</li>
				<li>Music and community events bringing surfers, families and friends together</li>
			</ul>
			<article class="event-card">
				<p class="reunion-body">
					The reunion is about reconnecting with old friends, meeting new ones, and honoring the shared love of the ocean that has defined Del Mar and its neighbors for generations.
				</p>
			</article>

			<h2 class="reunion-subhead">BE PART OF THE REUNION:</h2>
			<article class="event-card">
				<p class="reunion-body">
					Just like the Beach Boys song says, "You'll catch 'em surfin' at Del Mar," whether you surfed these waves decades ago or just recently discovered them, SURF DEL MAR welcomes you! Come celebrate the history, the stories and the community that grew from the surf at Del Mar.
				</p>
			</article>

			<article class="event-card event-card-cta">
				<h2 class="reunion-cta-heading">DO YOU HAVE A DEL MAR SURF STORY? SHARE IT WITH EVERYONE!</h2>
				<p class="reunion-cta-body">
					Send us your photos, your memories and names of people we should invite. We'll include them in the <strong>SHARED MEMORIES</strong> section of the website.
				</p>
				<a href="/schedule/" class="reunion-schedule-link">View full schedule</a>
			</article>
		</div>
	</section>
</BaseLayout>

<style>
	.hero {
		color: var(--color-cream);
		padding: 4rem 2rem;
		text-align: center;
	}

	.wave-wrap {
		position: relative;
		overflow: visible;
		min-height: 120px;
	}

	.wave-wrap :global(.wave-surfer-wrap) {
		transition: opacity 0.4s ease, visibility 0.4s ease;
	}
	:global(.wave-wrap.pirate-mode) :global(.wave-surfer-wrap) {
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
	}

	.hero-content {
		max-width: 700px;
		margin: 0 auto;
	}

	.hero h1 {
		font-family: var(--font-display);
		font-size: clamp(2.5rem, 5vw, 4rem);
		font-weight: 600;
		letter-spacing: 0.02em;
		margin-bottom: 1rem;
		line-height: 1.2;
	}

	.hero-title {
		animation: hero-fade-up 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
	}
	.hero-tagline {
		opacity: 0;
		animation: hero-fade-up 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.2s forwards;
	}
	@keyframes hero-fade-up {
		from {
			opacity: 0;
			transform: translateY(30px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.tagline {
		font-size: 1.25rem;
		opacity: 0.95;
		font-weight: 400;
	}

	.reunion-content {
		position: relative;
		z-index: 1;
		padding: 4rem 2rem;
		background: linear-gradient(180deg, #e8e0d6 0%, #ddd4c8 100%);
		box-shadow: inset 0 1px 0 rgba(255,255,255,0.4);
	}

	.reunion-content .container {
		max-width: 820px;
		margin: 0 auto;
	}

	.reunion-intro {
		font-family: var(--font-body);
		font-size: 1.0625rem;
		color: var(--color-ink);
		line-height: 1.75;
		margin: 0 0 1rem 0;
	}
	.reunion-intro:last-of-type {
		margin-bottom: 0;
	}

	.reunion-subhead {
		font-family: var(--font-body);
		font-size: clamp(1rem, 2.5vw, 1.2rem);
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-ink);
		margin: 2rem 0 0.75rem 0;
		line-height: 1.4;
	}

	.reunion-lead {
		font-family: var(--font-body);
		font-size: 1rem;
		color: var(--color-ink);
		line-height: 1.6;
		margin: 0 0 0.75rem 0;
	}

	.reunion-list {
		font-family: var(--font-body);
		font-size: 1rem;
		color: var(--color-ink);
		line-height: 1.75;
		margin: 0 0 1.5rem 0;
		padding-left: 1.5rem;
		list-style: disc;
	}
	.reunion-list li {
		margin-bottom: 0.35rem;
	}

	.reunion-body {
		font-family: var(--font-body);
		font-size: 1.0625rem;
		color: var(--color-ink);
		line-height: 1.75;
		margin: 0;
	}

	.event-card {
		background: rgba(255, 255, 255, 0.4);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		padding: 1.5rem 1.5rem 1.5rem 1.25rem;
		border-radius: 12px;
		border: 1px solid rgba(255, 255, 255, 0.5);
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
		border-left: 6px solid #8b7355;
		transition: transform 0.3s ease, box-shadow 0.3s ease;
		margin-bottom: 1.25rem;
	}

	.event-card:hover {
		transform: translateX(10px);
		box-shadow: 0 8px 28px rgba(0, 0, 0, 0.08);
	}

	.event-card-intro {
		margin-bottom: 1.5rem;
	}

	.event-card h3,
	.event-card h2 {
		font-family: var(--font-display);
		font-size: 1.2rem;
		font-weight: 600;
		color: var(--color-ink);
		margin: 0 0 0.6rem 0;
		line-height: 1.3;
	}

	.event-card p {
		font-family: var(--font-body);
		font-size: 1rem;
		color: var(--color-ink);
		line-height: 1.7;
		margin: 0;
	}

	.event-card-cta {
		text-align: center;
		border-left-color: var(--wave-deep);
		background: rgba(26, 95, 122, 0.08);
		margin-top: 2rem;
	}

	.reunion-cta-heading {
		font-family: var(--font-body) !important;
		font-size: clamp(0.95rem, 2.2vw, 1.1rem) !important;
		font-weight: 700 !important;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-ink);
		line-height: 1.45;
		margin: 0 0 0.75rem 0 !important;
	}

	.reunion-cta-body {
		font-family: var(--font-body);
		font-size: 1rem;
		color: var(--color-ink);
		line-height: 1.7;
		margin: 0 0 1.25rem 0;
	}

	.reunion-schedule-link {
		display: inline-block;
		font-family: var(--font-body);
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--wave-deep);
		text-decoration: none;
		padding: 0.5rem 1.25rem;
		border: 2px solid var(--wave-mid);
		border-radius: 50px;
		transition: background 0.25s ease, color 0.25s ease;
	}

	.reunion-schedule-link:hover {
		background: var(--wave-deep);
		color: var(--color-cream);
	}
</style>
