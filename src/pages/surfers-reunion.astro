---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollWaves from '../components/ScrollWaves.astro';
import WaveSurfer from '../components/WaveSurfer.astro';
import PirateShip from '../components/PirateShip.astro';
import Lighthouse from '../components/Lighthouse.astro';
---

<BaseLayout title="Surfers Reunion" description="A gathering of generations—Del Mar surfers past and present, together again.">
	<section class="hero hero-sunset-bg">
		<div class="hero-content hero-entrance">
			<h1 class="hero-title">SURFERS REUNION</h1>
			<p class="tagline hero-tagline">A Gathering of Generations</p>
		</div>
	</section>
	<div class="wave-wrap wave-hero hero-sunset-bg" id="reunion-wave-wrap">
		<ScrollWaves variant="light" />
		<WaveSurfer />
		<PirateShip />
		<Lighthouse toggleTargetId="reunion-wave-wrap" />
	</div>

	<section class="reunion-content">
		<div class="container">
			<div class="reunion-intro-grid">
				<div class="reunion-intro-image-col">
					<div class="reunion-surfers-wrap">
						<img src="/surfers.jpg" alt="Surfers at Del Mar" class="reunion-surfers-img" width="600" height="400" />
					</div>
				</div>
				<div class="reunion-intro-text-col">
					<p class="reunion-intro">
						For decades, surfers have gathered along our local beaches to ride the waves, and share stories, building a unique coastal culture. SURF DEL MAR brings these generations together again.
					</p>
					<p class="reunion-intro">
						From the pioneers who surfed here in the 1930s, like XXXXXXX, and into the 1950s and 60s, to today's surfers and young riders, this reunion invites everyone connected to Del Mar and the surrounding surf communities to come together and celebrate.
					</p>
				</div>
			</div>

			<h2 class="reunion-subhead">REMEMBERING THE WAVES</h2>
			<p class="reunion-lead">Throughout the SURF DEL MAR weekend, reunion events will include;</p>
			<ul class="reunion-list">
				<li>Informal gatherings and storytelling with surfers from different eras</li>
				<li>Historic photographs and shared memories from Del Mar's early surf days</li>
				<li>Film screenings celebrating classic surf culture</li>
				<li>Music and community events bringing surfers, families and friends together</li>
			</ul>
			<article class="event-card">
				<p class="reunion-body">
					The reunion is about reconnecting with old friends, meeting new ones, and honoring the shared love of the ocean that has defined Del Mar and its neighbors for generations.
				</p>
			</article>

			<h2 class="reunion-subhead">BE PART OF THE REUNION:</h2>
			<article class="event-card">
				<p class="reunion-body">
					Just like the Beach Boys song says, "You'll catch 'em surfin' at Del Mar," whether you surfed these waves decades ago or just recently discovered them, SURF DEL MAR welcomes you! Come celebrate the history, the stories and the community that grew from the surf at Del Mar.
				</p>
			</article>

			<article class="event-card event-card-cta">
				<h2 class="reunion-cta-heading">DO YOU HAVE A DEL MAR SURF STORY? SHARE IT WITH EVERYONE!</h2>
				<p class="reunion-cta-body">
					Send us your photos, your memories and names of people we should invite. We'll include them in the <strong>SHARED MEMORIES</strong> section below.
				</p>
				<button type="button" class="reunion-share-btn" id="reunion-share-memories-btn">Share your memories</button>
			</article>

			<h2 class="reunion-subhead reunion-memories-heading">SHARED MEMORIES</h2>
			<div id="shared-memories-container" class="shared-memories-container" aria-live="polite">
				<p id="shared-memories-loading" class="shared-memories-msg">Loading…</p>
			</div>
		</div>
	</section>

	<!-- Lightbox for photo zoom -->
	<div id="memory-lightbox" class="memory-lightbox" role="dialog" aria-modal="true" aria-label="View photo" hidden>
		<div class="memory-lightbox-overlay" id="memory-lightbox-overlay"></div>
		<div class="memory-lightbox-content">
			<button type="button" class="memory-lightbox-close" id="memory-lightbox-close" aria-label="Close">×</button>
			<img id="memory-lightbox-img" src="" alt="" class="memory-lightbox-img" />
		</div>
	</div>

	<!-- Share memories modal -->
	<div id="share-memories-modal" class="share-memories-modal" role="dialog" aria-labelledby="share-memories-title" aria-modal="true" hidden>
		<div class="share-memories-overlay" id="share-memories-overlay"></div>
		<div class="share-memories-box">
			<h2 id="share-memories-title" class="share-memories-title">Share your memories</h2>
			<form id="share-memories-form" class="share-memories-form">
				<label for="memory-photo" class="share-memories-label">Photo</label>
				<input type="file" id="memory-photo" name="photo" accept="image/*" required class="share-memories-file" />
				<label for="memory-caption" class="share-memories-label">Your memory (optional)</label>
				<textarea id="memory-caption" name="caption" class="share-memories-textarea" rows="3" placeholder="Tell us about this photo…" maxlength="1000"></textarea>
				<label for="memory-name" class="share-memories-label">Your name (optional)</label>
				<input type="text" id="memory-name" name="name" class="share-memories-input" placeholder="Name" maxlength="200" />
				<p id="share-memories-error" class="share-memories-error" aria-live="polite" hidden></p>
				<p id="share-memories-success" class="share-memories-success" aria-live="polite" hidden>Thank you! Your memory has been added.</p>
				<div class="share-memories-actions">
					<button type="button" class="share-memories-btn share-memories-cancel" id="share-memories-cancel">Cancel</button>
					<button type="submit" class="share-memories-btn share-memories-submit" id="share-memories-submit">Submit</button>
				</div>
			</form>
		</div>
	</div>

	<script>
		import { getSharedMemories } from '../lib/firebase';
		import type { SharedMemory } from '../lib/firebase';

		const SUBMIT_URL = '/.netlify/functions/submit-memory';
		const LIKE_URL = '/.netlify/functions/like-memory';
		// Firestore doc limit 1MB; base64 is ~4/3 of binary so keep binary ≤ ~700KB
		const MAX_IMAGE_SIZE = 700 * 1024;
		const MAX_DIMENSION = 1200; // max width or height before upload

		const openBtn = document.getElementById('reunion-share-memories-btn');
		const modal = document.getElementById('share-memories-modal');
		const overlay = document.getElementById('share-memories-overlay');
		const form = document.getElementById('share-memories-form');
		const cancelBtn = document.getElementById('share-memories-cancel');
		const fileInput = document.getElementById('memory-photo') as HTMLInputElement;
		const errorEl = document.getElementById('share-memories-error');
		const successEl = document.getElementById('share-memories-success');
		const containerEl = document.getElementById('shared-memories-container');
		const loadingEl = document.getElementById('shared-memories-loading');
		const lightbox = document.getElementById('memory-lightbox');
		const lightboxImg = document.getElementById('memory-lightbox-img') as HTMLImageElement;
		const lightboxOverlay = document.getElementById('memory-lightbox-overlay');
		const lightboxClose = document.getElementById('memory-lightbox-close');

		let memoriesList: SharedMemory[] = [];

		function randomRotation() {
			return (Math.random() * 6 - 3).toFixed(2);
		}

		function openModal() {
			if (modal) modal.hidden = false;
			if (errorEl) { errorEl.hidden = true; errorEl.textContent = ''; }
			if (successEl) successEl.hidden = true;
			if (form) form.reset();
		}
		function closeModal() {
			if (modal) modal.hidden = true;
		}

		function openLightbox(src: string, alt: string) {
			if (lightboxImg) { lightboxImg.src = src; lightboxImg.alt = alt; }
			if (lightbox) lightbox.hidden = false;
		}
		function closeLightbox() {
			if (lightbox) lightbox.hidden = true;
		}

		openBtn?.addEventListener('click', openModal);
		overlay?.addEventListener('click', closeModal);
		cancelBtn?.addEventListener('click', closeModal);
		lightboxOverlay?.addEventListener('click', closeLightbox);
		lightboxClose?.addEventListener('click', closeLightbox);

		async function renderMemories() {
			if (!containerEl) return;
			if (loadingEl) loadingEl.textContent = 'Loading…';
			const result = await getSharedMemories();
			if (loadingEl) loadingEl.remove();
			if (!result.ok) {
				containerEl.innerHTML = `<p class="shared-memories-msg shared-memories-error">Couldn't load memories. ${escapeHtml(result.error)} Check Netlify env vars (PUBLIC_FIREBASE_*) and that Firestore rules are deployed.</p>`;
				return;
			}
			memoriesList = result.memories.filter((m) => m.imageUrl && m.imageUrl.startsWith('data:'));
			if (memoriesList.length === 0) {
				containerEl.innerHTML = '<p class="shared-memories-msg">No memories yet. Be the first to share! If you already submitted a photo, try sharing again—earlier submissions may not have been saved.</p>';
				return;
			}
			const gridHtml = `
				<div class="memories-grid memories-grid-corkboard">
					${memoriesList.map((m) => {
						const rot = randomRotation();
						return `
						<article class="polaroid-card" style="--polaroid-rotate: ${rot}deg">
							<div class="polaroid-tape" aria-hidden="true"></div>
							<button type="button" class="polaroid-img-wrap" data-lightbox-src="${escapeHtml(m.imageUrl)}" data-lightbox-alt="${escapeHtml(m.caption || 'Shared memory')}">
								<img src="${m.imageUrl}" alt="${escapeHtml(m.caption || 'Shared memory')}" class="polaroid-img" loading="lazy" />
							</button>
							<div class="polaroid-like-wrap">
								<button type="button" class="polaroid-like-sticker memory-like-btn" data-memory-id="${escapeHtml(m.id)}" aria-label="Like this memory">
									<span class="memory-like-icon" aria-hidden="true">♥</span>
									<span class="memory-like-count">${m.likes}</span>
								</button>
							</div>
							<div class="polaroid-caption">${m.caption ? escapeHtml(m.caption) : ''}</div>
							${m.name ? `<div class="polaroid-name">— ${escapeHtml(m.name)}</div>` : ''}
						</article>`;
					}).join('')}
				</div>
			`;
			containerEl.innerHTML = gridHtml;

			containerEl.querySelectorAll('.polaroid-img-wrap').forEach((btn) => {
				btn.addEventListener('click', () => {
					const src = btn.getAttribute('data-lightbox-src');
					const alt = btn.getAttribute('data-lightbox-alt') || '';
					if (src) openLightbox(src, alt);
				});
			});

			containerEl.querySelectorAll('.memory-like-btn').forEach((btn) => {
				btn.addEventListener('click', async (e) => {
					e.stopPropagation();
					const el = e.currentTarget as HTMLElement;
					const id = el.getAttribute('data-memory-id');
					if (!id) return;
					el.setAttribute('disabled', '');
					try {
						const res = await fetch(LIKE_URL, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ memoryId: id }) });
						const data = await res.json().catch(() => ({}));
						if (res.ok && typeof data.likes === 'number') {
							const mem = memoriesList.find((x) => x.id === id);
							if (mem) mem.likes = data.likes;
							const countEl = el.querySelector('.memory-like-count');
							if (countEl) countEl.textContent = String(data.likes);
						}
					} finally {
						el.removeAttribute('disabled');
					}
				});
			});
		}

		function escapeHtml(s: string) {
			const div = document.createElement('div');
			div.textContent = s;
			return div.innerHTML;
		}

		form?.addEventListener('submit', async (e) => {
			e.preventDefault();
			if (!errorEl || !successEl || !fileInput) return;
			errorEl.hidden = true;
			successEl.hidden = true;
			const file = fileInput.files?.[0];
			if (!file) {
				errorEl.textContent = 'Please choose a photo.';
				errorEl.hidden = false;
				return;
			}
			const caption = (document.getElementById('memory-caption') as HTMLTextAreaElement)?.value?.trim() || '';
			const name = (document.getElementById('memory-name') as HTMLInputElement)?.value?.trim() || '';
			const submitBtn = document.getElementById('share-memories-submit') as HTMLButtonElement;
			submitBtn.disabled = true;
			try {
				const { base64, contentType } = await compressImageForUpload(file, MAX_IMAGE_SIZE, MAX_DIMENSION);
				if (!base64) {
					errorEl.textContent = 'Photo is too large. We couldn\'t shrink it enough—try a smaller image.';
					errorEl.hidden = false;
					return;
				}
				const res = await fetch(SUBMIT_URL, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({
						imageBase64: base64,
						contentType,
						caption,
						name,
					}),
				});
				const data = await res.json().catch(() => ({}));
				if (!res.ok) {
					if (res.status === 404) {
						errorEl.textContent = 'Submit isn\'t available here. Run "npm run dev:netlify" for local testing, or use the deployed site.';
					} else {
						errorEl.textContent = (data && data.error) ? String(data.error) : `Something went wrong (${res.status}). Please try again.`;
					}
					errorEl.hidden = false;
					return;
				}
				successEl.hidden = false;
				await renderMemories();
				setTimeout(closeModal, 1500);
			} catch (err) {
				const msg = err instanceof Error ? err.message : 'Something went wrong. Please try again.';
				errorEl.textContent = msg;
				errorEl.hidden = false;
			} finally {
				submitBtn.disabled = false;
			}
		});

		/** Resize/compress image to stay under maxSizeBytes; returns base64 + contentType or null if still too big. */
		async function compressImageForUpload(file: File, maxSizeBytes: number, maxDim: number): Promise<{ base64: string; contentType: string } | { base64: null; contentType: string }> {
			const contentType = 'image/jpeg';
			if (!file.type.startsWith('image/')) return { base64: null, contentType };

			const img = await loadImage(file);
			const { width, height } = img;
			const scale = Math.min(1, maxDim / Math.max(width, height));
			const w = Math.round(width * scale);
			const h = Math.round(height * scale);

			const canvas = document.createElement('canvas');
			canvas.width = w;
			canvas.height = h;
			const ctx = canvas.getContext('2d');
			if (!ctx) return { base64: null, contentType };
			ctx.drawImage(img, 0, 0, w, h);

			for (const q of [0.85, 0.7, 0.55, 0.4, 0.25]) {
				const blob = await new Promise<Blob | null>((res) => canvas.toBlob(res, 'image/jpeg', q));
				if (!blob) continue;
				if (blob.size <= maxSizeBytes) {
					const base64 = await blobToBase64(blob);
					return { base64, contentType };
				}
			}
			return { base64: null, contentType };
		}

		function loadImage(file: File): Promise<HTMLImageElement> {
			return new Promise((resolve, reject) => {
				const url = URL.createObjectURL(file);
				const img = new Image();
				img.onload = () => { URL.revokeObjectURL(url); resolve(img); };
				img.onerror = () => { URL.revokeObjectURL(url); reject(new Error('Image load failed')); };
				img.src = url;
			});
		}

		function blobToBase64(blob: Blob): Promise<string> {
			return new Promise((resolve, reject) => {
				const reader = new FileReader();
				reader.onload = () => {
					const result = reader.result as string;
					const base64 = result.split(',')[1];
					resolve(base64 || '');
				};
				reader.onerror = reject;
				reader.readAsDataURL(blob);
			});
		}

		renderMemories();
	</script>
</BaseLayout>

<style>
	.hero {
		color: var(--color-cream);
		padding: 4rem 2rem;
		text-align: center;
	}

	.wave-wrap {
		position: relative;
		overflow: visible;
		min-height: 120px;
	}

	.wave-wrap :global(.wave-surfer-wrap) {
		transition: opacity 0.4s ease, visibility 0.4s ease;
	}
	:global(.wave-wrap.pirate-mode) :global(.wave-surfer-wrap) {
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
	}

	.hero-content {
		max-width: 700px;
		margin: 0 auto;
	}

	.hero h1 {
		font-family: var(--font-display);
		font-size: clamp(2.5rem, 5vw, 4rem);
		font-weight: 600;
		letter-spacing: 0.02em;
		margin-bottom: 1rem;
		line-height: 1.2;
	}

	.hero-title {
		animation: hero-fade-up 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
	}
	.hero-tagline {
		opacity: 0;
		animation: hero-fade-up 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.2s forwards;
	}
	@keyframes hero-fade-up {
		from {
			opacity: 0;
			transform: translateY(30px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.tagline {
		font-size: 1.25rem;
		opacity: 0.95;
		font-weight: 400;
	}

	.reunion-content {
		position: relative;
		z-index: 1;
		padding: 4rem 2rem;
		background: linear-gradient(180deg, #e8e0d6 0%, #ddd4c8 100%);
		box-shadow: inset 0 1px 0 rgba(255,255,255,0.4);
	}

	.reunion-content .container {
		max-width: 820px;
		margin: 0 auto;
	}

	.reunion-intro-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem;
		align-items: center;
		margin-bottom: 2.5rem;
	}

	@media (max-width: 768px) {
		.reunion-intro-grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
		.reunion-intro-image-col {
			order: 1;
		}
		.reunion-intro-text-col {
			order: 2;
		}
	}

	.reunion-surfers-wrap {
		display: flex;
		justify-content: center;
		align-items: center;
	}

	.reunion-surfers-img {
		width: 100%;
		max-width: 380px;
		height: auto;
		display: block;
		border-radius: 6px;
		box-shadow: 0 20px 50px rgba(0,0,0,0.18), 0 8px 24px rgba(0,0,0,0.12);
		transform: rotate(-2deg);
		transition: transform 0.35s ease, box-shadow 0.35s ease;
	}

	.reunion-surfers-wrap:hover .reunion-surfers-img {
		transform: rotate(0deg);
		box-shadow: 0 24px 56px rgba(0,0,0,0.2);
	}

	.reunion-intro-text-col .reunion-intro {
		margin-top: 0;
	}

	.reunion-intro {
		font-family: var(--font-body);
		font-size: 1.0625rem;
		color: var(--color-ink);
		line-height: 1.75;
		margin: 0 0 1rem 0;
	}
	.reunion-intro:last-of-type {
		margin-bottom: 0;
	}

	.reunion-subhead {
		font-family: var(--font-body);
		font-size: clamp(1rem, 2.5vw, 1.2rem);
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-ink);
		margin: 2rem 0 0.75rem 0;
		line-height: 1.4;
	}

	.reunion-lead {
		font-family: var(--font-body);
		font-size: 1rem;
		color: var(--color-ink);
		line-height: 1.6;
		margin: 0 0 0.75rem 0;
	}

	.reunion-list {
		font-family: var(--font-body);
		font-size: 1rem;
		color: var(--color-ink);
		line-height: 1.75;
		margin: 0 0 1.5rem 0;
		padding-left: 1.5rem;
		list-style: disc;
	}
	.reunion-list li {
		margin-bottom: 0.35rem;
	}

	.reunion-body {
		font-family: var(--font-body);
		font-size: 1.0625rem;
		color: var(--color-ink);
		line-height: 1.75;
		margin: 0;
	}

	.event-card {
		background: rgba(255, 255, 255, 0.4);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		padding: 1.5rem 1.5rem 1.5rem 1.25rem;
		border-radius: 12px;
		border: 1px solid rgba(255, 255, 255, 0.5);
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
		border-left: 6px solid #8b7355;
		transition: transform 0.3s ease, box-shadow 0.3s ease;
		margin-bottom: 1.25rem;
	}

	.event-card:hover {
		transform: translateX(10px);
		box-shadow: 0 8px 28px rgba(0, 0, 0, 0.08);
	}

	.event-card-intro {
		margin-bottom: 1.5rem;
	}

	.event-card h3,
	.event-card h2 {
		font-family: var(--font-display);
		font-size: 1.2rem;
		font-weight: 600;
		color: var(--color-ink);
		margin: 0 0 0.6rem 0;
		line-height: 1.3;
	}

	.event-card p {
		font-family: var(--font-body);
		font-size: 1rem;
		color: var(--color-ink);
		line-height: 1.7;
		margin: 0;
	}

	.event-card-cta {
		text-align: center;
		border-left-color: var(--wave-deep);
		background: rgba(26, 95, 122, 0.08);
		margin-top: 2rem;
	}

	.reunion-cta-heading {
		font-family: var(--font-body) !important;
		font-size: clamp(0.95rem, 2.2vw, 1.1rem) !important;
		font-weight: 700 !important;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-ink);
		line-height: 1.45;
		margin: 0 0 0.75rem 0 !important;
	}

	.reunion-cta-body {
		font-family: var(--font-body);
		font-size: 1rem;
		color: var(--color-ink);
		line-height: 1.7;
		margin: 0 0 1.25rem 0;
	}

	.reunion-share-btn {
		display: inline-block;
		font-family: var(--font-body);
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--wave-deep);
		background: transparent;
		text-decoration: none;
		padding: 0.5rem 1.25rem;
		border: 2px solid var(--wave-mid);
		border-radius: 50px;
		cursor: pointer;
		transition: background 0.25s ease, color 0.25s ease;
	}

	.reunion-share-btn:hover {
		background: var(--wave-deep);
		color: var(--color-cream);
	}

	@import url('https://fonts.googleapis.com/css2?family=Kalam:wght@400;700&display=swap');

	.reunion-memories-heading {
		margin-top: 3rem;
	}

	.shared-memories-container {
		margin-top: 1rem;
	}

	.shared-memories-msg {
		font-family: var(--font-body);
		color: var(--color-sepia);
		font-style: italic;
		margin: 0;
	}

	.shared-memories-error {
		font-style: normal;
		color: var(--color-ink);
		max-width: 48ch;
	}

	/* Corkboard masonry grid */
	.memories-grid-corkboard {
		background: linear-gradient(180deg, #8b6914 0%, #6b4a0a 100%);
		background-image:
			repeating-linear-gradient(
				90deg,
				transparent,
