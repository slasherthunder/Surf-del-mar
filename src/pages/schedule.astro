---
import BaseLayout from '../layouts/BaseLayout.astro';
import type { ScheduleEvent } from '../lib/firebase';

const EVENT_CATEGORIES = ['General', 'Music', 'Film', 'Symposium', 'Reunion', 'Exhibition', 'Parade', 'Reception', 'Other'];

function makeId() {
  return `ev-${Date.now()}-${Math.random().toString(36).slice(2, 9)}`;
}

const initialEvents: ScheduleEvent[] = [
  { id: makeId(), date: '2026-10-08', startTime: '15:00', endTime: '18:30', title: 'Opening Reception — Meet and Greet · Surfing Art Walk · Music by Peter Sprague and group', venue: 'Del Mar Plaza', category: 'Reception', description: '', advocacy: false },
  { id: makeId(), date: '2026-10-08', startTime: '10:00', endTime: '15:00', title: 'Climate Change / Conservation Symposium', venue: "St. Peter's Hall", category: 'Symposium', description: '', advocacy: true },
  { id: makeId(), date: '2026-10-09', startTime: '11:00', endTime: '17:00', title: 'Surfing Film Festival', venue: "St. Peter's Hall", category: 'Film', description: 'Daytime 11am–5pm · Evening 6pm–9pm', advocacy: false },
  { id: makeId(), date: '2026-10-10', startTime: '11:00', endTime: '21:00', title: "Surfer's Reunion", venue: 'Powerhouse Park', category: 'Reunion', description: '', advocacy: false },
  { id: makeId(), date: '2026-10-10', startTime: '10:00', endTime: '15:00', title: "Surfwriter's Book Fair", venue: 'TBD', category: 'Exhibition', description: '', advocacy: false },
  { id: makeId(), date: '2026-10-10', startTime: '11:00', endTime: '15:00', title: 'Woody Wagon Parade Through Del Mar and Display', venue: 'Del Mar Train Station', category: 'Parade', description: '', advocacy: false },
  { id: makeId(), date: '2026-10-10', startTime: '14:00', endTime: '16:30', title: 'Afternoon Concert with The MarDels', venue: 'Powerhouse Park', category: 'Music', description: '', advocacy: false },
  { id: makeId(), date: '2026-10-10', startTime: '17:00', endTime: '19:00', title: 'VIP Reception', venue: 'Community Room at Powerhouse Park', category: 'Reception', description: '', advocacy: false },
  { id: makeId(), date: '2026-10-10', startTime: '18:00', endTime: '21:00', title: 'Film Presentation: Endless Summer', venue: 'Powerhouse Park Stage', category: 'Film', description: '', advocacy: false },
  { id: makeId(), date: '2026-10-11', startTime: '10:00', endTime: '15:00', title: "Surfwriter's Book Fair", venue: 'TBD', category: 'Exhibition', description: '', advocacy: false },
  { id: makeId(), date: '2026-10-11', startTime: '10:00', endTime: '15:00', title: 'Student Art Walk', venue: 'TBD', category: 'Exhibition', description: '', advocacy: false },
];
---

<BaseLayout title="Festival Schedule" description="Surf Del Mar 4-day festival schedule — October 8–11, 2026.">
	<section class="hero schedule-hero">
		<div class="hero-content">
			<span class="eyebrow">4-Day Event</span>
			<h1 class="hero-title">Surf Del Mar Schedule</h1>
			<p class="tagline">October 8–11, 2026</p>
		</div>
	</section>

	<section class="schedule-content">
		<div class="container schedule-inner" id="schedule-edit-root">
			<!-- Filled by script -->
		</div>
	</section>

	<script id="schedule-config" type="application/json" set:html={JSON.stringify({ initialEvents, categories: EVENT_CATEGORIES })}></script>
	<script>
		import { getSchedule } from '../lib/firebase';

		const root = document.getElementById('schedule-edit-root');
		const configEl = document.getElementById('schedule-config');
		const config = configEl ? JSON.parse(configEl.textContent || '{}') : { initialEvents: [], categories: ['General'] };
		const INITIAL_EVENTS = config.initialEvents || [];
		const CATEGORIES = config.categories || ['General'];
		const ADMIN_PASSWORD = typeof import.meta.env.PUBLIC_ADMIN_PASSWORD === 'string' && import.meta.env.PUBLIC_ADMIN_PASSWORD
			? import.meta.env.PUBLIC_ADMIN_PASSWORD
			: 'surfdelmar';
		const DRAFT_KEY = 'surf-del-mar-schedule-draft';
		const DRAFT_TIMESTAMP_KEY = 'surf-del-mar-schedule-draft-at';

		function escapeHtml(s) {
			const div = document.createElement('div');
			div.textContent = s ?? '';
			return div.innerHTML;
		}

		function formatTime24to12(t) {
			if (!t) return '';
			const [h, m] = t.split(':').map(Number);
			const period = h >= 12 ? 'pm' : 'am';
			const h12 = h % 12 || 12;
			return `${h12}:${String(m || 0).padStart(2, '0')} ${period}`;
		}

		function formatDate(dateStr) {
			if (!dateStr) return '';
			const d = new Date(dateStr + 'T12:00:00');
			const ord = (n) => {
				const s = ['th', 'st', 'nd', 'rd'];
				const v = n % 100;
				return s[(v - 20) % 10] || s[v] || s[0];
			};
			const days = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
			const month = d.toLocaleString('en', { month: 'long' });
			const dayNum = d.getDate();
			return `${days[d.getDay()]}, ${month} ${dayNum}${ord(dayNum)}`;
		}

		function legacyToEvents(legacy) {
			if (!Array.isArray(legacy)) return [];
			const makeId = () => `ev-${Date.now()}-${Math.random().toString(36).slice(2, 9)}`;
			const events = [];
			const parseTime = (s) => {
				const m = (s || '').match(/(\d{1,2}):?(\d{2})?\s*(am|pm)/i);
				if (!m) return null;
				let h = parseInt(m[1], 10);
				const min = parseInt(m[2] || '0', 10);
				if ((m[3] || '').toLowerCase() === 'pm' && h < 12) h += 12;
				if ((m[3] || '').toLowerCase() === 'am' && h === 12) h = 0;
				return `${String(h).padStart(2, '0')}:${String(min).padStart(2, '0')}`;
			};
			for (const day of legacy) {
				const dayStr = day.day || '';
				const dateMatch = dayStr.match(/(\d{1,2})\D*(\d{1,2})?(?:\D*(\d{4}))?/);
				const date = dateMatch ? `${dateMatch[3] || '2026'}-10-${String(parseInt(dateMatch[1], 10)).padStart(2, '0')}` : '2026-10-08';
				for (const ev of day.events || []) {
					const timeStr = ev.time || '';
					const parts = timeStr.split(/\s+to\s+|\s*[-–—]\s*|·/i).map(p => p.trim()).filter(Boolean);
					const start = parseTime(parts[0]) || '09:00';
					const end = parseTime(parts[1]) || '17:00';
					events.push({
						id: ev.id || makeId(),
						date,
						startTime: ev.startTime || start,
						endTime: ev.endTime || end,
						title: ev.title || '',
						venue: ev.venue || 'TBD',
						category: ev.category || 'General',
						description: ev.description || '',
						advocacy: !!ev.advocacy,
					});
				}
			}
			return events;
		}

		function groupByDate(events) {
			const byDate = {};
			for (const e of events) {
				const d = e.date || '2026-10-08';
				if (!byDate[d]) byDate[d] = [];
				byDate[d].push(e);
			}
			for (const arr of Object.values(byDate)) {
				arr.sort((a, b) => (a.startTime || '').localeCompare(b.startTime || ''));
			}
			return byDate;
		}

		function validateEvent(ev) {
			const errs = [];
			if (!(ev.title || '').trim()) errs.push('Title is required');
			if (!(ev.venue || '').trim()) errs.push('Venue is required');
			const s = (ev.startTime || '').replace(/:/g, '');
			const e = (ev.endTime || '').replace(/:/g, '');
			if (s && e && s >= e) errs.push('Start time must be before end time');
			return errs;
		}

		function validateAll(events) {
			let ok = true;
			for (const ev of events) {
				if (validateEvent(ev).length) ok = false;
			}
			return ok;
		}

		function saveDraft(events) {
			try {
				localStorage.setItem(DRAFT_KEY, JSON.stringify(events));
				localStorage.setItem(DRAFT_TIMESTAMP_KEY, String(Date.now()));
			} catch (_) {}
		}

		function loadDraft() {
			try {
				const raw = localStorage.getItem(DRAFT_KEY);
				const at = localStorage.getItem(DRAFT_TIMESTAMP_KEY);
				if (raw && at) return { events: JSON.parse(raw), at: Number(at) };
			} catch (_) {}
			return null;
		}

		const FESTIVAL_DATES = ['2026-10-08', '2026-10-09', '2026-10-10', '2026-10-11'];

		function render(events, options) {
			if (!root) return;
			const showEdit = options.showEdit !== false;
			const previewMode = options.previewMode === true;
			const errors = options.errors || {};
			const byDate = groupByDate(events);
			const dates = [...new Set([...FESTIVAL_DATES, ...Object.keys(byDate)])].sort();

			const timeInput = (ev, field) => {
				if (!showEdit || previewMode) return escapeHtml(formatTime24to12(ev[field]));
				const val = ev[field] || '';
				return `<input type="time" class="schedule-input schedule-time" data-id="${escapeHtml(ev.id)}" data-field="${field}" value="${escapeHtml(val)}" step="300" />`;
			};

			const catSelect = (ev) => {
				if (!showEdit || previewMode) return escapeHtml(ev.category || 'General');
				const opts = CATEGORIES.map(c => `<option value="${escapeHtml(c)}" ${(ev.category || '') === c ? 'selected' : ''}>${escapeHtml(c)}</option>`).join('');
				return `<select class="schedule-input schedule-select" data-id="${escapeHtml(ev.id)}" data-field="category">${opts}</select>`;
			};

			const pinIcon = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>';

			let html = '';
			if (showEdit && previewMode) {
				html += `
					<div class="schedule-toolbar schedule-preview-bar">
						<button type="button" class="btn btn-primary" id="schedule-back-to-edit">Back to edit mode</button>
					</div>`;
			}
			if (showEdit && !previewMode) {
				html += `
					<div class="schedule-toolbar">
						<label class="schedule-preview-toggle"><input type="checkbox" id="schedule-preview-mode" /> Preview mode</label>
						<button type="button" class="btn btn-outline" id="schedule-undo" title="Undo">Undo</button>
						<button type="button" class="btn btn-outline" id="schedule-redo" title="Redo">Redo</button>
						<button type="button" class="btn btn-primary" id="schedule-add-event">Add event</button>
						<button type="button" class="btn btn-outline" id="schedule-reset">Reset to original</button>
						<button type="button" class="btn btn-primary" id="schedule-save">
							<span class="schedule-save-text">Save changes</span>
							<span class="schedule-spinner" hidden aria-hidden="true"></span>
						</button>
						<span class="schedule-last-saved" id="schedule-last-saved"></span>
					</div>`;
			}
			if (options.lastUpdated) {
				const el = document.getElementById('schedule-last-saved');
				if (el) el.textContent = `Last saved: ${new Date(options.lastUpdated).toLocaleString()}`;
			}

			for (const date of dates) {
				const dayEvents = byDate[date] || [];
				const dayTitleHtml = showEdit && !previewMode
					? `<input type="date" class="schedule-input schedule-day-date" data-date="${escapeHtml(date)}" value="${escapeHtml(date)}" />`
					: `<h2 class="schedule-day-title">${escapeHtml(formatDate(date))}</h2>`;
				html += `<div class="schedule-day" data-date="${escapeHtml(date)}">
					${dayTitleHtml}
					<div class="schedule-day-events">`;
				if (dayEvents.length === 0) {
					html += `<div class="schedule-day-empty">
						<p class="schedule-day-empty-text">No events scheduled</p>
						${showEdit && !previewMode ? `<button type="button" class="btn btn-outline schedule-add-day-event" data-date="${escapeHtml(date)}">Add event</button>` : ''}
					</div>`;
				}
				for (const ev of dayEvents) {
					const err = (errors[ev.id] || []).join('; ');
					const errClass = err ? ' schedule-event-has-error' : '';
					const advClass = ev.advocacy ? ' event-card-advocacy' : '';
					html += `
						<article class="event-card${advClass}${errClass}" data-id="${escapeHtml(ev.id)}" data-date="${escapeHtml(date)}" draggable="${showEdit && !previewMode ? 'true' : 'false'}">
							${showEdit && !previewMode ? `<span class="event-drag-handle" aria-label="Drag to reorder">⋮⋮</span>` : ''}
							<div class="event-card-body">
								<div class="event-header-row">
									<div class="schedule-meta-time">${timeInput(ev, 'startTime')} – ${timeInput(ev, 'endTime')}</div>
									${(ev.category || (showEdit && !previewMode)) ? `<span class="cat-pill">${catSelect(ev)}</span>` : ''}
								</div>
								${showEdit && !previewMode
									? `<input type="text" class="schedule-input schedule-title" data-id="${escapeHtml(ev.id)}" data-field="title" value="${escapeHtml(ev.title || '')}" placeholder="Event title" />`
									: `<h3>${escapeHtml(ev.title || '')}</h3>`}
								${err ? `<p class="schedule-error" role="alert">${escapeHtml(err)}</p>` : ''}
								<div class="venue-badge">
									${pinIcon}
									${showEdit && !previewMode
										? `<input type="text" class="schedule-input schedule-venue" data-id="${escapeHtml(ev.id)}" data-field="venue" value="${escapeHtml(ev.venue || '')}" placeholder="Venue" />`
										: `<span>${escapeHtml(ev.venue || '')}</span>`}
								</div>
								${(ev.description || '') && (showEdit && !previewMode) ? `<input type="text" class="schedule-input schedule-desc" data-id="${escapeHtml(ev.id)}" data-field="description" value="${escapeHtml(ev.description || '')}" placeholder="Description (optional)" />` : ''}
								${(ev.description || '') && (showEdit === false || previewMode) ? `<p class="schedule-desc-text">${escapeHtml(ev.description)}</p>` : ''}
								${showEdit && !previewMode ? `<button type="button" class="event-delete-btn" aria-label="Delete event">×</button>` : ''}
							</div>
						</article>`;
				}
				html += `</div></div>`;
			}
			root.innerHTML = html;
		}

		function getEventById(events, id) {
			return events.find(e => e.id === id);
		}

		function updateEvent(events, id, field, value) {
			const ev = getEventById(events, id);
			if (ev) ev[field] = value;
			return [...events];
		}

		function reattach(events, state) {
			const pushState = () => {
				state.undoStack.push(JSON.stringify(events));
				if (state.undoStack.length > 50) state.undoStack.shift();
				state.redoStack = [];
				saveDraft(events);
			};
			const setEvents = (next) => {
				state.events = next;
				render(state.events, { showEdit: true, previewMode: state.previewMode, errors: state.errors, lastUpdated: state.lastUpdated });
				reattach(state.events, state);
			};

			root.querySelectorAll('.schedule-input').forEach(input => {
				const id = input.dataset.id;
				const field = input.dataset.field;
				if (!id || !field) return;
				const ev = getEventById(events, id);
				if (!ev) return;
				input.addEventListener('change', () => {
					const val = input.value;
					pushState();
					setEvents(updateEvent(state.events, id, field, val));
				});
				input.addEventListener('input', () => {
					ev[field] = input.value;
					saveDraft(state.events);
				});
			});

			root.querySelectorAll('.event-delete-btn').forEach(btn => {
				btn.addEventListener('click', () => {
					const card = btn.closest('.event-card');
					const id = card?.dataset.id;
					if (!id) return;
					pushState();
					setEvents(state.events.filter(e => e.id !== id));
				});
			});

			document.getElementById('schedule-back-to-edit')?.addEventListener('click', () => {
				state.previewMode = false;
				render(state.events, { showEdit: true, previewMode: false, errors: state.errors, lastUpdated: state.lastUpdated });
				reattach(state.events, state);
			});

			const previewCheck = document.getElementById('schedule-preview-mode');
			if (previewCheck) {
				previewCheck.checked = state.previewMode;
				previewCheck.addEventListener('change', () => {
					state.previewMode = previewCheck.checked;
					render(state.events, { showEdit: true, previewMode: state.previewMode, errors: state.errors, lastUpdated: state.lastUpdated });
					reattach(state.events, state);
				});
			}

			root.querySelectorAll('.schedule-day-date').forEach(input => {
				input.addEventListener('change', () => {
					const oldDate = input.dataset.date;
					const newDate = (input as HTMLInputElement).value;
					if (!oldDate || !newDate || oldDate === newDate) return;
					pushState();
					const next = state.events.map(ev => ev.date === oldDate ? { ...ev, date: newDate } : ev);
					setEvents(next);
				});
			});

			document.getElementById('schedule-reset')?.addEventListener('click', () => {
				if (!state.originalEvents) return;
				if (!confirm('Reset to the last loaded schedule? Unsaved edits will be lost.')) return;
				pushState();
				setEvents(JSON.parse(JSON.stringify(state.originalEvents)));
			});

			document.getElementById('schedule-undo')?.addEventListener('click', () => {
				if (state.undoStack.length === 0) return;
				const prev = state.undoStack.pop();
				state.redoStack.push(JSON.stringify(state.events));
				state.events = JSON.parse(prev);
				render(state.events, { showEdit: true, previewMode: state.previewMode, errors: state.errors, lastUpdated: state.lastUpdated });
				reattach(state.events, state);
			});

			document.getElementById('schedule-redo')?.addEventListener('click', () => {
				if (state.redoStack.length === 0) return;
				const next = state.redoStack.pop();
				state.undoStack.push(JSON.stringify(state.events));
				state.events = JSON.parse(next);
				render(state.events, { showEdit: true, previewMode: state.previewMode, errors: state.errors, lastUpdated: state.lastUpdated });
				reattach(state.events, state);
			});

			const addEventForDate = (date) => {
				pushState();
				const newEv = {
					id: `ev-${Date.now()}-${Math.random().toString(36).slice(2, 9)}`,
					date: date || '2026-10-10',
					startTime: '10:00',
					endTime: '12:00',
					title: 'New Event',
					venue: 'TBD',
					category: 'General',
					description: '',
					advocacy: false,
				};
				setEvents([...state.events, newEv]);
			};

			document.getElementById('schedule-add-event')?.addEventListener('click', () => {
				const dateStr = prompt('Date (YYYY-MM-DD)', '2026-10-10');
				if (!dateStr) return;
				const date = dateStr.match(/^\d{4}-\d{2}-\d{2}$/) ? dateStr : '2026-10-10';
				addEventForDate(date);
			});

			root.querySelectorAll('.schedule-add-day-event').forEach(btn => {
				btn.addEventListener('click', () => {
					const date = btn.getAttribute('data-date');
					if (date) addEventForDate(date);
				});
			});

			const saveBtn = document.getElementById('schedule-save');
			saveBtn?.addEventListener('click', async () => {
				const errs = {};
				for (const ev of state.events) {
					const e = validateEvent(ev);
					if (e.length) errs[ev.id] = e;
				}
				state.errors = errs;
				if (Object.keys(errs).length > 0) {
					render(state.events, { showEdit: true, previewMode: state.previewMode, errors: errs, lastUpdated: state.lastUpdated });
					reattach(state.events, state);
					return;
				}
				const spinner = saveBtn?.querySelector('.schedule-spinner');
				const saveText = saveBtn?.querySelector('.schedule-save-text');
				if (spinner) spinner.hidden = false;
				if (saveText) saveText.textContent = 'Saving…';
				try {
					const res = await fetch('/.netlify/functions/save-schedule', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({
							password: ADMIN_PASSWORD,
							events: state.events.map((ev) => ({
								id: ev.id,
								date: ev.date,
								startTime: ev.startTime,
								endTime: ev.endTime,
								title: ev.title ?? '',
								venue: ev.venue ?? 'TBD',
								category: ev.category ?? 'General',
								description: ev.description ?? '',
								advocacy: !!ev.advocacy,
							})),
						}),
					});
					const data = await res.json().catch(() => ({}));
					if (res.ok && data.ok) {
						state.lastUpdated = data.lastUpdated;
						window.dispatchEvent(new CustomEvent('show-admin-toast', { detail: { message: 'Saved successfully.' } }));
						render(state.events, { showEdit: true, previewMode: state.previewMode, errors: {}, lastUpdated: state.lastUpdated });
						reattach(state.events, state);
					} else {
						const msg = data.error || `Save failed (${res.status}).`;
						const hint = res.status === 403 ? ' Check ADMIN_PASSWORD matches PUBLIC_ADMIN_PASSWORD.'
							: res.status === 404 ? ' Run "npx netlify dev" or deploy to Netlify.'
							: res.status === 500 ? ' Check Netlify env: ADMIN_PASSWORD, FIREBASE_SERVICE_ACCOUNT.'
							: '';
						alert(msg + hint);
					}
				} catch (e) {
					const errMsg = e && typeof e.message === 'string' ? e.message : 'Network or server error';
					alert('Save failed: ' + errMsg + '. Run "npx netlify dev" or deploy to Netlify.');
				} finally {
					if (spinner) spinner.hidden = true;
					if (saveText) saveText.textContent = 'Save changes';
				}
			});

			// Drag and drop
			let draggedEl = null;
			let draggedId = null;
			root.querySelectorAll('.event-card[draggable="true"]').forEach(card => {
				card.addEventListener('dragstart', (e) => {
					draggedEl = card;
					draggedId = card.dataset.id;
					e.dataTransfer?.setData('text/plain', card.dataset.id || '');
					card.classList.add('event-dragging');
				});
				card.addEventListener('dragend', () => {
					card.classList.remove('event-dragging');
					draggedEl = null;
					draggedId = null;
				});
				card.addEventListener('dragover', (e) => {
					e.preventDefault();
					const target = e.currentTarget;
					if (target !== draggedEl && target.classList.contains('event-card')) {
						target.classList.add('event-drag-over');
					}
				});
				card.addEventListener('dragleave', (e) => {
					e.currentTarget.classList.remove('event-drag-over');
				});
				card.addEventListener('drop', (e) => {
					e.preventDefault();
					e.currentTarget.classList.remove('event-drag-over');
					if (!draggedId) return;
					const targetCard = e.currentTarget;
					const targetId = targetCard.dataset.id;
					const targetDate = targetCard.dataset.date;
					if (!targetId || targetId === draggedId) return;
					const ev = getEventById(state.events, draggedId);
					if (!ev) return;
					pushState();
					const next = state.events.filter(e => e.id !== draggedId);
					const targetIdx = next.findIndex(e => e.id === targetId);
					ev.date = targetDate || ev.date;
					const insertIdx = targetIdx >= 0 ? targetIdx : next.length;
					next.splice(insertIdx, 0, ev);
					setEvents(next);
				});
			});
		}

		async function init() {
			let events = [...INITIAL_EVENTS];
			let lastUpdated = null;
			const fromFirebase = await getSchedule();
			if (fromFirebase) {
				if ('events' in fromFirebase && Array.isArray(fromFirebase.events)) {
					events = fromFirebase.events;
					lastUpdated = fromFirebase.lastUpdated || null;
				} else if ('legacy' in fromFirebase && Array.isArray(fromFirebase.legacy)) {
					events = legacyToEvents(fromFirebase.legacy);
				}
			}
			const originalEvents = JSON.parse(JSON.stringify(events));
			const isAdmin = sessionStorage.getItem('admin') === 'true';
			if (isAdmin) {
				const draft = loadDraft();
				if (draft && draft.events.length && confirm('Restore unsaved draft?')) {
					events = draft.events;
				}
			}
			const state = {
				events,
				originalEvents,
				previewMode: false,
				errors: {} as Record<string, string[]>,
				lastUpdated,
				undoStack: [] as string[],
				redoStack: [] as string[],
			};
			render(state.events, {
				showEdit: isAdmin,
				previewMode: false,
				errors: {},
				lastUpdated: state.lastUpdated,
			});
			if (isAdmin) reattach(state.events, state);
		}
		init();
	</script>
</BaseLayout>

